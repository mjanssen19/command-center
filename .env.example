# Paperclip integration
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=

# WebSocket URL for Paperclip real-time updates (client-side)
NEXT_PUBLIC_PAPERCLIP_WS_URL=ws://localhost:3100

# OpenClaw workspace — root path to scan for local files
OPENCLAW_WORKSPACE_PATH=/path/to/openclaw/workspace

# External integrations (Phase 9) — all optional
MEM0_API_KEY=          # Mem0 API key for memory integration
SUPERMEMORY_API_KEY=   # Supermemory API key for memory integration
CALENDAR_ICS_URL=      # External calendar ICS feed URL
